{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "HelloPay API Documentation",
  "appearance": {
    "default": "light",
    "strict": false
  },
  "colors": {
    "primary": "#0F63FF",
    "light": "#0F63FF",
    "dark": "#0F63FF"
  },
  "favicon": "/favicon.svg",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "bash",
        "typescript"
      ],
      "defaults": "required",
      "prefill": true
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "play",
              "pages": [
                "index",
                "getting-started/authentication",
                "getting-started/sandbox",
                "getting-started/webhooks"
              ]
          },
          {
            "group": "Guides",
            "icon": "notebook-text",
            "pages": [
              {
                "group": "Payins",
                "icon": "wallet",
                "pages": [
                  "guides/how-to-create-first-payin",
                  "guides/payin-pse",
                  "guides/payin-breb"
                ]
              },
              "guides/how-to-create-first-payout"
            ]
          },
          {
            "group": "API reference",
            "icon": "square-terminal",
            "openapi": "https://api.hellopay.com.co/api-yaml",
            "pages": [
              {
                "group": "Payins",
                "icon": "code",
                "pages": [
                  "POST /payins",
                  "GET /payins",
                  "GET /payins/{id}"
                ]
              },
              {
                "group": "Payouts",
                "icon": "code",
                "pages": [
                  "POST /payouts",
                  "GET /payouts",
                  "GET /payouts/{id}"
                ]
              },
              {
                "group": "Ledger",
                "icon": "list",
                "pages": [
                  "GET /ledger/balance",
                  "GET /ledger/entries"
                ]
              },
              {
                "group": "BreB",
                "icon": "wallet",
                "pages": [
                  "GET /breb/keys/{keyString}"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://hellopay.com.co/"
      },
      {
        "label": "Support",
        "href": "mailto:support@hellopay.com.co"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Client Portal",
      "href": "https://portal.hellopay.com.co"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {}
}
